FROM node:20-alpine

WORKDIR /app

# Install build tools for node-gyp
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source
COPY . .

# Expose Payload CMS port
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]
